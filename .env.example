# ── Court Reserve ─────────────────────────────────────────────────────────────
# Your Court Reserve admin login credentials.
# CR_LOGIN_URL: your org's login page — log in at app.courtreserve.com, then
#   copy the URL from the address bar (it ends with your org ID, e.g. /12345)
# CR_USERNAME:  your admin email address
# CR_PASSWORD:  your admin password
CR_LOGIN_URL=https://app.courtreserve.com/Online/Account/LogIn/YOUR_ORG_ID
CR_USERNAME=your_admin_email@example.com
CR_PASSWORD=your_admin_password

# ── Discord ───────────────────────────────────────────────────────────────────
# Webhook URL — used for posting recommendation and booking result embeds.
# Create at: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Bot token — required for the listener to read replies in the channel.
# Create at: https://discord.com/developers/applications → New Application →
#   Bot → Reset Token. Enable MESSAGE CONTENT INTENT under Privileged Gateway Intents.
DISCORD_BOT_TOKEN=your_bot_token_here

# Channel ID — right-click the channel in Discord → Copy Channel ID
# (Developer Mode must be on: User Settings → Advanced → Developer Mode)
DISCORD_CHANNEL_ID=your_channel_id_here

# ── Anthropic / Claude API ────────────────────────────────────────────────────
# Used for LLM-powered recommendations (--llm flag) and !book command parsing.
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here
